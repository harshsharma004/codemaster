CodeMaster_ENVIRONMENT=development
CodeMaster_SECRET_KEY=replace-this-with-a-long-random-secret
CodeMaster_DATABASE_URL=sqlite:///./CodeMaster.db
CodeMaster_DATABASE_AUTO_MIGRATE=false
CodeMaster_DATABASE_POOL_SIZE=10
CodeMaster_DATABASE_MAX_OVERFLOW=20
CodeMaster_DATABASE_POOL_RECYCLE_SECONDS=1800
CodeMaster_ACCESS_TOKEN_EXPIRE_MINUTES=1440
CodeMaster_ENABLE_DOCS=false
CodeMaster_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
CodeMaster_ALLOWED_HOSTS=localhost,127.0.0.1
CodeMaster_SEED_DEMO_DATA=true
CodeMaster_RUN_STARTUP_TASKS_ON_APP_START=true
CodeMaster_AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
CodeMaster_AUTH_RATE_LIMIT_WINDOW_SECONDS=300
CodeMaster_FRIEND_LOOKUP_RATE_LIMIT_MAX_ATTEMPTS=20
CodeMaster_FRIEND_LOOKUP_RATE_LIMIT_WINDOW_SECONDS=60
CodeMaster_ENABLE_ADMIN=false
CodeMaster_ADMIN_EMAILS=
CodeMaster_ADMIN_RATE_LIMIT_MAX_ATTEMPTS=5
CodeMaster_ADMIN_RATE_LIMIT_WINDOW_SECONDS=300
CodeMaster_FORWARDED_ALLOW_IPS=
CodeMaster_SESSION_COOKIE_NAME=CodeMaster-admin-session
CodeMaster_GOOGLE_CLIENT_ID=
CodeMaster_GOOGLE_CLIENT_SECRET=
CodeMaster_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
PORT=8000
