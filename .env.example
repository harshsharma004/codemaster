MYSQL_DATABASE=CodeMaster
MYSQL_USER=CodeMaster
MYSQL_PASSWORD=replace-with-a-strong-database-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-strong-root-password
CodeMaster_SECRET_KEY=replace-with-a-long-random-secret
# Render / hosted MySQL-compatible database:
# mysql://USER:PASSWORD@HOST:4000/CodeMaster?parseTime=true&charset=utf8mb4
CodeMaster_DATABASE_URL=mysql://user:password@host:4000/CodeMaster?parseTime=true&charset=utf8mb4
# Enable TLS for hosted MySQL-compatible databases such as TiDB Cloud Starter.
CodeMaster_DATABASE_SSL_CA_PATH=/etc/ssl/certs/ca-certificates.crt
CodeMaster_DATABASE_SSL_VERIFY_CERT=true
CodeMaster_DATABASE_SSL_VERIFY_IDENTITY=true
# Set this to your deployed frontend origin, for example:
# https://trie-quest.vercel.app
CodeMaster_CORS_ORIGINS=https://trie-quest.vercel.app
# Render host plus local hosts used by health checks.
CodeMaster_ALLOWED_HOSTS=CodeMaster-api.onrender.com,127.0.0.1,localhost
CodeMaster_DATABASE_AUTO_MIGRATE=false
CodeMaster_SEED_DEMO_DATA=false
CodeMaster_AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
CodeMaster_AUTH_RATE_LIMIT_WINDOW_SECONDS=300
CodeMaster_FRIEND_LOOKUP_RATE_LIMIT_MAX_ATTEMPTS=20
CodeMaster_FRIEND_LOOKUP_RATE_LIMIT_WINDOW_SECONDS=60
CodeMaster_ENABLE_ADMIN=false
CodeMaster_ADMIN_EMAILS=
CodeMaster_ADMIN_RATE_LIMIT_MAX_ATTEMPTS=5
CodeMaster_ADMIN_RATE_LIMIT_WINDOW_SECONDS=300
CodeMaster_ENABLE_DOCS=false
# TiDB Cloud Starter closes idle connections after 5 minutes; recycle pooled
# connections early to avoid stale pooled sessions on Render.
CodeMaster_DATABASE_POOL_RECYCLE_SECONDS=300
CodeMaster_SESSION_COOKIE_NAME=CodeMaster-admin-session
# Separate frontend deployments should use an absolute API URL.
VITE_API_BASE_URL=https://CodeMaster-api.onrender.com
